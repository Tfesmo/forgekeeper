{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "rules": {
    "noVar": "error",
    "camelCase": "error",
    "upperCase": "error",
    "noSingleCharVariables": "error",
    "indent": ["error", 2],
    "trailingComma": "error",
    "noThen": "error",
    "noEmptyCatch": "error",
    "throwString": "error",
    "noUnusedImports": "error",
    "requireJsDoc": "warn"
  },
  "plugins": ["react", "jsdoc", "vitest", "import"],
 
}
